# ============================================
# AzerothCore Docker - 环境配置
# 从群晖 SPK WoWServer v1.0.52 迁移
# Author: asm0x1
# ============================================
# 复制此文件为 .env 并修改对应配置:
#   cp .env.dist .env
# ============================================

# ============================================
# 服务器地址 (必填，改为你的本机局域网IP)
# ============================================
REALM_IP=127.0.0.1

# ============================================
# 服务端口
# ============================================
DOCKER_AUTH_EXTERNAL_PORT=3724
DOCKER_WORLD_EXTERNAL_PORT=8085
DOCKER_SOAP_EXTERNAL_PORT=7878
DOCKER_DB_EXTERNAL_PORT=63306
DOCKER_REGISTRATION_EXTERNAL_PORT=8765

# ============================================
# 数据库密码
# ============================================
DOCKER_DB_ROOT_PASSWORD=wow@asm0x1

# ============================================
# 默认管理员账户 (首次启动自动创建)
# 留空则不创建默认账户
# ============================================
DEFAULT_ACCOUNT_USER=asm0x1
DEFAULT_ACCOUNT_PASS=123456
DEFAULT_ACCOUNT_GMLEVEL=3
DEFAULT_ACCOUNT_EXPANSION=2

# ============================================
# 客户端数据路径 (maps/dbc/vmaps/mmaps)
# ============================================
DOCKER_CLIENT_DATA_PATH=./data

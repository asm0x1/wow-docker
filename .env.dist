# ============================================
# AzerothCore Docker - 环境配置
# 从群晖 SPK WoWServer v1.0.52 迁移
# Author: asm0x1
# ============================================
# 复制此文件为 .env 并修改对应配置:
#   cp .env.dist .env
# ============================================

# ============================================
# 服务器地址 (必填，改为你的本机局域网IP)
# ============================================
REALM_IP=127.0.0.1

# ============================================
# 服务端口
# ============================================
DOCKER_AUTH_EXTERNAL_PORT=3724
DOCKER_WORLD_EXTERNAL_PORT=8085
DOCKER_SOAP_EXTERNAL_PORT=7878
DOCKER_DB_EXTERNAL_PORT=63306
DOCKER_REGISTRATION_EXTERNAL_PORT=8765

# ============================================
# 数据库密码
# ============================================
DOCKER_DB_ROOT_PASSWORD=wow@asm0x1

# ============================================
# 额外自定义管理员账户 (可选，首次启动自动创建)
# 内置账户 asm0x1/123456 (GM 3) 始终存在，无需配置
# 此处可添加你自己的管理员账户，留空则跳过
# ============================================
#DEFAULT_ACCOUNT_USER=
#DEFAULT_ACCOUNT_PASS=
#DEFAULT_ACCOUNT_GMLEVEL=3
#DEFAULT_ACCOUNT_EXPANSION=2

# ============================================
# Playerbots 假人系统 (可选)
# 更多配置见 conf/modules/playerbots.conf.dist
# ============================================
BOT_MIN_COUNT=15      # 最小在线假人数量
BOT_MAX_COUNT=20      # 最大在线假人数量
BOT_MIN_LEVEL=1       # 假人最低等级
BOT_MAX_LEVEL=80      # 假人最高等级
BOT_ALLIANCE_RATIO=50 # 联盟阵营比例 (%)
BOT_HORDE_RATIO=50    # 部落阵营比例 (%)


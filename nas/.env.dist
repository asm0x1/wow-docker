# ============================================
# AzerothCore WotLK 3.3.5a - 绿联 NAS 环境配置
# 适配: DXP4800 Plus (Intel 8505 x86_64)
# Author: asm0x1
# ============================================
#
# 此文件为可选参考模板。主要配置已移到 docker-compose.yml 顶部：
#   x-deploy-config:
#     REALM_IP:      192.168.1.100   # 改 NAS IP
#     DB_ROOT_PASS:  wow@asm0x1       # 改密码
#
# 如果复制此文件为 .env 并放入项目目录，realm-init.sh 会在
# 启动时自动加载（作为 docker-compose.yml 的补充）。
# ============================================

# ============================================
# 服务器地址
# ============================================
REALM_IP=192.168.1.100

# ============================================
# 服务端口
# ============================================
DOCKER_AUTH_EXTERNAL_PORT=3724
DOCKER_WORLD_EXTERNAL_PORT=8085
DOCKER_SOAP_EXTERNAL_PORT=7878
DOCKER_DB_EXTERNAL_PORT=63306
DOCKER_REGISTRATION_EXTERNAL_PORT=8765

# ============================================
# 数据库密码
# ============================================
DOCKER_DB_ROOT_PASSWORD=wow@asm0x1

# ============================================
# 额外自定义管理员账户 (可选)
# 内置 asm0x1/123456 (GM 3) 始终存在
# ============================================
#DEFAULT_ACCOUNT_USER=
#DEFAULT_ACCOUNT_PASS=
#DEFAULT_ACCOUNT_GMLEVEL=3
#DEFAULT_ACCOUNT_EXPANSION=2

# ============================================
# Playerbots 假人系统 (可选)
# ============================================
BOT_MIN_COUNT=15
BOT_MAX_COUNT=20
BOT_MIN_LEVEL=1
BOT_MAX_LEVEL=80
BOT_ALLIANCE_RATIO=50
BOT_HORDE_RATIO=50
